# ============================================
# HR Bot Configuration
# ============================================

# DATABASE - PostgreSQL connection string
# Local: postgresql://user:password@localhost/hr_bot_db
# Docker: postgresql://hrbot:hrbot_dev_password@postgres:5432/hr_bot_db
DATABASE_URL=postgresql://user:password@localhost/hr_bot_db

# ============================================
# TELEGRAM BOT
# ============================================

# Get from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# For production (webhook mode)
# Local development uses polling by default
TELEGRAM_WEBHOOK_URL=https://your-domain.com

# ============================================
# OUTLOOK / MICROSOFT GRAPH
# ============================================

# Azure App Registration details
# Get these from Azure Portal → App registrations

# Your Azure tenant ID (e.g., xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
OUTLOOK_TENANT_ID=your_azure_tenant_id

# Application (client) ID
OUTLOOK_CLIENT_ID=your_azure_app_id

# Client secret value (keep this secret!)
OUTLOOK_CLIENT_SECRET=your_azure_app_secret

# OAuth redirect URI
# Local: http://localhost:8000/auth/outlook/callback
# Production: https://your-domain.com/auth/outlook/callback
OUTLOOK_REDIRECT_URI=http://localhost:8000/auth/outlook/callback

# ============================================
# APPLICATION SETTINGS
# ============================================

# Enable debug mode (more verbose logging)
DEBUG=False

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# User's timezone (IANA timezone, e.g., Asia/Jerusalem, Europe/London, America/New_York)
TIMEZONE=Asia/Jerusalem
